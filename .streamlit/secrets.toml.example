# Copy this file to `.streamlit/secrets.toml` and fill in your key.
# `.streamlit/secrets.toml` is gitignored — never commit your real key.
# On Streamlit Community Cloud, paste these under App → Settings → Secrets instead.
#
# The SAME Google AI Studio key you used for Gemini works for Gemma — just set the
# model to a Gemma tag. Get/reuse a key at https://aistudio.google.com/apikey

SHOKHI_BACKEND = "gemini"
SHOKHI_GEMMA_MODEL = "gemma-4-26b-a4b-it"   # efficient MoE; or "gemma-4-31b-it" (flagship)
GOOGLE_API_KEY = "paste-your-google-ai-studio-key-here"
