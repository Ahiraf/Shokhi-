# Make CI/Vercel installs resilient.
# 1) Retry registry fetches that get aborted mid-download (the ECONNRESET that failed the
#    Vercel build) instead of failing the whole install on one transient network blip.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000

# 2) Don't hard-fail on peer-dependency mismatches (vitest 4 / vite 8 vs @types/node are
#    dev-only and only produce warnings). Keeps the tree installable across Node versions.
legacy-peer-deps=true
