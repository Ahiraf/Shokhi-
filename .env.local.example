# Local dev config for Shokhi (Next.js). Copy to .env.local (git-ignored).
# The backend now lives inside this same app (app/api/*), so there is NO separate server.

# Real Gemma 4 via Google AI Studio — SERVER-SIDE only (never exposed to the browser).
# Get a free key at https://aistudio.google.com. Without any key, the app falls back to a
# deterministic mock backend so everything still runs.
GOOGLE_API_KEY=paste_your_key_here

# Optional extra keys (from different Google accounts) for automatic quota fallback:
# GOOGLE_API_KEY_2=
# GOOGLE_API_KEY_3=

# Optional overrides:
# SHOKHI_GEMMA_MODEL=gemma-4-26b-a4b-it
# SHOKHI_BACKEND=gemini            # force "gemini" or "mock"
# SHOKHI_LLM_EXTRACT=0             # keep off for the faster deterministic intake path
# SHOKHI_SAFETY_NET=0              # optional extra Gemma safety check; deterministic triage stays on

# Optional: only if you point the frontend at an EXTERNAL backend instead of this app.
# NEXT_PUBLIC_API_URL=
